 drivers/net/bonding/bond_3ad.c       |    4 +++
 drivers/net/bonding/bond_netlink.c   |   16 +++++++++++++++
 drivers/net/bonding/bond_options.c   |   36 +++++++++++++++++++++++++++++++++++
