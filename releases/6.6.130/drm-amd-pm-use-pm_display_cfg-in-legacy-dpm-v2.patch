+			      (adev->pm.pm_display_cfg.num_display >= 3) || pi->video_start);
 
 		if (force_high) {
 			for (i = pi->lowest_valid; i <= pi->highest_valid; i++)
--- a/drivers/gpu/drm/amd/pm/legacy-dpm/legacy_dpm.c
